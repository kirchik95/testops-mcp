{
  "name": "testops-mcp",
  "version": "1.5.3",
  "description": "MCP server for TestOps — test management, launches, defects, and test results",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "testops-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "rm -rf build && tsc -p tsconfig.build.json",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm test && npm run build && npm run docs:lint && npm run guardrails",
    "docs:lint": "node scripts/docs-lint.mjs",
    "guardrails": "node scripts/guardrails.mjs",
    "eval:smoke": "npm run build && node scripts/eval-smoke.mjs",
    "eval:matrix": "npm run build && node scripts/eval-matrix.mjs",
    "prepare": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testops",
    "test-management",
    "qa"
  ],
  "author": "k.martynov",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
